<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- Run: mvn clean test -P parallel -->
<!--
  Parallel execution rules:
  - parallel="classes": each class runs in its own thread
  - thread-count="2": max 2 browser sessions concurrently
  - WebDriver is stored in ThreadLocal (DriverManager) for thread safety
  - @AfterMethod(alwaysRun = true) ensures driver is quit and removed
  - Avoid static/shared WebDriver references across tests
  - Each test class manages its own setUp/tearDown independently
  - Do not increase thread-count beyond available system resources
  - Do not use parallel="methods" unless each method is fully isolated
-->
<suite name="Parallel Suite" parallel="classes" thread-count="2">
    <listeners>
        <listener class-name="automation.listener.TestListener"/>
    </listeners>
    <test name="Parallel Tests">
        <classes>
            <class name="automation.LoginTest"/>
            <class name="automation.LoginPageOpenTest"/>
        </classes>
    </test>
</suite>
